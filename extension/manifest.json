{
  "manifest_version": 3,
  "name": "TruthCatcher - News Fact Check",
  "version": "1.0",
  "description": "One-click news fact-checking with AI",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  }
}
